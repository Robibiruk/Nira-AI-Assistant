# JARVIS LLM provider keys — set ANY of these to enable each provider.
# No key => that provider is skipped. JARVIS rotates across the ones you set
# automatically on rate limits (so one provider's daily cap won't take it down).

# 1) OpenRouter (huge free catalogue; free tool-capable models auto-discovered)
OPENROUTER_API_KEY=

# 2) Groq (fast, free Llama/Mixtral)
GROQ_API_KEY=

# 3) Together AI (free-ish Llama/Qwen/Mixtral)
TOGETHER_API_KEY=

# 4) DeepSeek (cheap, strong reasoning)
DEEPSEEK_API_KEY=

# 5) Mistral (free Mistral/Ministral tier)
MISTRAL_API_KEY=

# 6) GitHub Models (free models via GitHub Marketplace)
GITHUB_TOKEN=

# Optional: host/port for the PC server (python run.py)
JARVIS_HOST=127.0.0.1
JARVIS_PORT=8000

# Optional: Kokoro voice tuning (defaults shown)
# JARVIS_KOKORO_VOICE=bm_george
# JARVIS_KOKORO_LANG=en-gb
# JARVIS_KOKORO_SPEED=1.0
