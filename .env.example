# ---- NIRA OAuth / integration storage ----
# Copy to `.env` and fill in. `.env` is git-ignored — never commit it.

# MongoDB connection string (separate DB from other apps).
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.XXXX.mongodb.net/

# Fernet key used to encrypt OAuth tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# Where the user is sent back to after connecting (the Integrations UI).
OAUTH_RETURN_TO=/?tab=settings

# Public backend origin used to build provider callback redirects.
# On Render this is set automatically via RENDER_EXTERNAL_URL; you can also
# hardcode it here, e.g. https://nira-ai-backend.onrender.com
OAUTH_REDIRECT_BASE=

# Frontend origin (so CORS + cookies work cross-origin on Vercel).
WEB_ORIGIN=https://nira-ai-assistant.vercel.app

# ---- Provider OAuth client credentials (NEVER sent to the frontend) ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
