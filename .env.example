# Nira AI - environment variables
# Copy to .env (auto-loaded by config.py) and fill in. Shell exports win.
# For deployment, set the same keys in your host (Render / Railway / Fly).

# --- LLM provider keys (set any to enable; no key => provider skipped) ---
# OpenRouter (huge free catalogue; tool-capable models auto-discovered)
OPENROUTER_API_KEY=
# Groq (fast, free Llama/Mixtral)
GROQ_API_KEY=
# Together AI (free-ish Llama/Qwen/Mixtral)
TOGETHER_API_KEY=
# DeepSeek (cheap, strong reasoning)
DEEPSEEK_API_KEY=
# Mistral (free Mistral/Ministral tier)
MISTRAL_API_KEY=
# NVIDIA Nim (hosted open models)
NVIDIA_API_KEY=
# GitHub Models (free models via GitHub Marketplace)
GITHUB_TOKEN=

# --- Tool API keys (optional; only needed for the matching tool) ---
# Web / research search
TAVILY_API_KEY=
# YouTube search
YOUTUBE_API_KEY=
# PubMed search (optional, raises rate limit)
NCBI_API_KEY=

# --- Server bind (used by `python run.py`; for uvicorn/Render use $PORT) ---
NIRA_HOST=127.0.0.1
NIRA_PORT=8000

# --- Kokoro TTS voice tuning (defaults shown; uncomment to override) ---
# JARVIS_KOKORO_VOICE=bm_george
# JARVIS_KOKORO_LANG=en-gb
# JARVIS_KOKORO_SPEED=1.0

# --- Frontend (Vercel): set in the Vercel dashboard, NOT here ---
# Point the SPA at your deployed backend so chat/voice work in prod.
# VITE_API_BASE=https://your-render-service.onrender.com
