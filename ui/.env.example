# Firebase web config (client-side, public by design).
# The web apiKey is NOT a secret — Firebase security comes from Security
# Rules + Anonymous Auth, not key secrecy. Set this once:
#   copy this file to .env and paste your REAL web apiKey (from
#   Firebase console > Project settings > Your apps > SDK setup),
#   then also add VITE_FIREBASE_API_KEY in Vercel's Environment Variables.
VITE_FIREBASE_API_KEY=PASTE_YOUR_FIREBASE_WEB_API_KEY_HERE
