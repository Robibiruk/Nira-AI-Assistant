# JARVIS configuration.
# Secrets can also be supplied via environment variables (see config.py).

openrouter:
# Get a free key at https://openrouter.ai/keys
# Or set the OPENROUTER_API_KEY environment variable instead.
  api_key: ""

# The active model. Leave empty to auto-select the first configured provider's
# first model (recommended with multi-provider fallback). Otherwise set a
# scoped id like "openrouter|meta-llama/llama-3.3-70b-instruct:free" or
# "groq|llama-3.3-70b-versatile".
model: ""

# Any OpenRouter model id works if you pin one. Free options (availability changes):
# qwen/qwen3-32b:free deepseek/deepseek-r1:free meta-llama/llama-...:free
# Changing this single value swaps the "brain" — nothing else changes.

voice: false # STT/TTS is wired in later versions
memory: sqlite # sqlite for MVP; chromadb later
temperature: 0.7

# Restrict which tools are available. Empty list = all tools enabled.
tools:
  enabled: []
# enabled:
# - open_browser
# - run_terminal_command
# - read_file
# - write_file
# - list_directory
# - open_app
# - get_weather
# - web_search
