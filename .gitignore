# ==========================================
# JARVIS - Git Ignore Rules
# ==========================================

# ==========================================
# Python
# ==========================================
.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environment folders
env/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# ==========================================
# Environment Variables
# ==========================================
# Backend environment
.env
.env.*
.env.example

# Frontend environment (in ui/ folder)
ui/.env
ui/.env.*
ui/.env.example

# Specific environment files
OPENROUTER_API_KEY

# ==========================================
# Database
# ==========================================
database/
*.db
*.sqlite
*.sqlite3
memory.db

# ==========================================
# OS Generated Files
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# Logs
# ==========================================
*.log
logs/

# ==========================================
# UI / Frontend
# ==========================================
ui/node_modules/
ui/dist/
ui/build/

# ==========================================
# Testing
# ==========================================
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/

# ==========================================
# Misc
# ==========================================
*.bak
*.tmp
*.temp

# local/custom LLM provider keys (user-added via Settings)
config/custom_providers.json
