# ==========================================
# NIRA - Git Ignore Rules
# ==========================================

# ==========================================
# Python
# ==========================================
.venv/
__pycache__/
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environment folders
env/
venv/
ENV/

# Python specific
.python-version

# ==========================================
# IDE
# ==========================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ==========================================
# Security - API Keys & Secrets
# ==========================================
# Never commit files that may contain real secrets/keys.
*.key
*.keys
*.secret
*.token
*.pem
*.crt
*.pfx

# Local config that may hold secrets — keep the example, ignore the real one.
config/settings.yaml
!config/settings.yaml.example

# Custom provider keys, external tool keys, feature flags (user-added).
config/custom_providers.json
config/tool_keys.json
config/features.json

# ==========================================
# Environment Variables
# ==========================================
.env
.env.*
!.env.example
ui/.env
ui/.env.*
!ui/.env.example
OPENROUTER_API_KEY
**/.env
**/.env.*
!**/.env.example

# ==========================================
# Build & Distribution
# ==========================================
*.exe
*.dll
*.dylib
*.app
*.msi
*.dmg
.pkg

# ==========================================
# Database
# ==========================================
database/
*.db
*.sqlite
*.sqlite3
memory.db

# ==========================================
# Logs
# ==========================================
*.log
logs/

# ==========================================
# UI / Frontend (build artifacts)
# ==========================================
ui/node_modules/
ui/dist/
ui/build/

# ==========================================
# Testing
# ==========================================
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/

# ==========================================
# Misc
# Misc
*.bak
*.tmp
*.temp

# Vercel
.vercel/