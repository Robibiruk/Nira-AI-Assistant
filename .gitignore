# ==========================================
# JARVIS - Git Ignore Rules
# ==========================================

# ==========================================
# Python
# ==========================================
.venv/
__pycache__/
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environment folders
env/
venv/
ENV/

# Python specific
.python-version

# ==========================================
# IDE
# ==========================================
.idea/
.vscode/
*.swp
*.swo
*~

# ==========================================
# Security - API Keys & Secrets
# ==========================================
# Never commit these files with real API keys
*.key
*.keys
*.secret
*.token
*.pem
*.crt
*.pfx

# Local configuration files that may contain secrets
*.local.json
*.config.json
!config/settings.yaml

# local/custom LLM provider keys (user-added via Settings)
config/custom_providers.json
# external tool API keys (Google, GitHub, Spotify, ...)
config/tool_keys.json
config/features.json
# Configuration file with potential secrets
config/settings.yaml
!config/settings.yaml.example

# ==========================================
# Environment Variables
# ==========================================
# Backend environment
.env
.env.*
!.env.example

# Frontend environment (in ui/ folder)
ui/.env
ui/.env.*
!ui/.env.example

# Specific environment files
OPENROUTER_API_KEY

# Any environment files in subdirectories
**/.env
**/.env.*
!**/.env.example

# ==========================================
# Build & Distribution
# ==========================================
*.exe
*.dll
*.dylib
*.app
*.msi
*.dmg
.pkg

# ==========================================
# Database
# ==========================================
database/
*.db
*.sqlite
*.sqlite3
memory.db

# ==========================================
# OS Generated Files
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# Logs
# ==========================================
*.log
logs/

# ==========================================
# UI / Frontend
# ==========================================
ui/node_modules/
ui/dist/
ui/build/

# ==========================================
# Testing
# ==========================================
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/

# ==========================================
# Misc
# ==========================================
*.bak
*.tmp
*.temp
